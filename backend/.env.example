# ─────────────────────────────────────────────────────────────────────────────
# Mythic Games — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# ── PostgreSQL (choose one connection method) ─────────────────────────────────
# Option A — Connection string (recommended for cloud deployments)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B — Individual fields (recommended for local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mythic_games
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST be changed before deploying to production.
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-strong-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-this-with-a-different-strong-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Cart / Commerce ──────────────────────────────────────────────────
# VAT / sales tax applied to all cart totals (0.13 = 13%).
CART_TAX_RATE=0.13

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── eSewa Payment Gateway ─────────────────────────────────────────────────────
# UAT / sandbox (safe for local development and CI)
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_PAYMENT_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_VERIFICATION_URL=https://rc-epay.esewa.com.np/api/epay/transaction/v2/status/
ESEWA_SUCCESS_URL=http://localhost:5000/api/payment/esewa/success
ESEWA_FAILURE_URL=http://localhost:5000/api/payment/esewa/failure

# PRODUCTION — replace with live credentials when deploying:
# ESEWA_MERCHANT_CODE=YOUR_LIVE_CODE
# ESEWA_SECRET_KEY=YOUR_LIVE_SECRET
# ESEWA_PAYMENT_URL=https://epay.esewa.com.np/api/epay/main/v2/form
# ESEWA_VERIFICATION_URL=https://epay.esewa.com.np/api/epay/transaction/v2/status/
# ESEWA_SUCCESS_URL=https://api.yourdomain.com/api/payment/esewa/success
# ESEWA_FAILURE_URL=https://api.yourdomain.com/api/payment/esewa/failure
