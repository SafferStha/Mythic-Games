# Copy this file to `.env` and fill in your PostgreSQL settings.
# Prefer DATABASE_URL when you want one explicit connection string for your team.

PORT=5000



DB_USER=your_postgres_user
DB_HOST=localhost
DB_NAME=your_database_name
DB_PASSWORD=your_database_password
DB_PORT=5432
DB_SSL=false

JWT_SECRET=your_super_secret_jwt_token_signing_key_here
JWT_EXPIRES_IN=7d

